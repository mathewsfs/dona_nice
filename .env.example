# Domínio onde o app vai rodar
APP_DOMAIN=donanice.fluxora.space

# Email para certificado Let's Encrypt (Traefik)
TRAEFIK_ACME_EMAIL=seuemail@exemplo.com

# Segredo JWT para autenticação (gerar um forte)
JWT_SECRET=gerar-um-segredo-forte-aqui-256bits

# URL do Frontend para CORS (obrigatório em produção)
FRONTEND_URL=https://donanice.fluxora.space

# Ambiente
NODE_ENV=production

# Porta do servidor
PORT=3001
