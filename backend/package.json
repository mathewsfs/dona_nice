{
  "name": "dona-nice-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon --watch src --exec node src/index.js",
    "build:frontend": "npm --prefix ../frontend run build",
    "copy:frontend": "node scripts/copy-frontend-dist.js",
    "build:prod": "npm run build:frontend && npm run copy:frontend",
    "package:win": "npm run build:prod && pkg . --targets node18-win-x64 --output dist/dona-nice.exe"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "pkg": "^5.8.1"
  },
  "bin": "src/index.js",
  "pkg": {
    "assets": [
      "public/**/*",
      "data/db.json"
    ]
  }
}
